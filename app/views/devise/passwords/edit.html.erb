<h2>Change your password</h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>
  <%= f.hidden_field :reset_password_token %>

  <div class="field">
    <%= f.password_field :password, autofocus: true, autocomplete: "new-password", label_as_placeholder: true %>
  </div>

  <div class="field">
    <%= f.password_field :password_confirmation,
                         label: 'Confirm new Password',
                         autocomplete: "new-password",
                         label_as_placeholder: true,
                         help: "Must be at least <%= #{@minimum_password_length} characters long" %>
  </div>

  <div class="actions">
    <%= f.primary "Change my password" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
