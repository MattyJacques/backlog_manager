<h2>Sign up</h2>

<%= bootstrap_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <%= f.text_field  :username, autofocus: true, autocomplete: "username", label_as_placeholder: true %>
  </div>

  <div class="field">
    <%= f.email_field :email, autocomplete: "email", label_as_placeholder: true %>
  </div>

  <div class="field">
    <%= f.password_field :password,
                         autocomplete: "new-password",
                         label_as_placeholder: true,
                         help: "Must be at least <%= #{@minimum_password_length} characters long" %>
  </div>

  <div class="field">
    <%= f.password_field :password_confirmation,
                         label: 'Confirm Password',
                         autocomplete: "new-password",
                         label_as_placeholder: true %>
  </div>

  <div class="actions">
    <%= f.primary "Sign up" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
