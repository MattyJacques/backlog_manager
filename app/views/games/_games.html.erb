<div id="search" class="text-end">
  <%= form_with url: list_games_path,
                method: :get,
                data: { controller: "search-form", search_form_target: "form", turbo_frame: "games" } do |f| %>
    <%= f.text_field :name,
                      placeholder: "Search...",
                      value: session.dig('game_filters', 'name'),
                      autocomplete: "off",
                      data: { action: "input->search-form#search"},
                      class: "form-control form-control-dark text-bg-dark" %>
    <%= f.select :platform_id,
                 options_for_select(
                   Platform.all.pluck(:name, :id),
                   session.dig('game_filters', 'platform_id')
                 ),
                 { include_blank: 'All Platforms' },
                 data: { action: "change->search-form#search" },
                 class: "form-control form-control-dark text-bg-dark form-select" %>
  <% end %>
</div>
<%= turbo_frame_tag "games" do %>
  <table id="games_table" class="table table-striped table-hover table-dark">
    <thead>
      <tr>
        </th scope="col">
        <th scope="col">
          <%= build_order_link(label: "Name", sort_by: "name") %>
          <%= sort_indicator if session.dig('game_filters', 'sort_by') == "name" %>
        </th>
        <th scope="col">
          <%= build_order_link(label: "Platforms", sort_by: "platform") %>
          <%= sort_indicator if session.dig('game_filters', 'sort_by') == "platform" %>
        </th>
        <% if user_signed_in? %>
          <th scope="col">
            <%= build_order_link(label: "Status", sort_by: "status") %>
            <%= sort_indicator if session.dig('game_filters', 'sort_by') == "status" %>
          </th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% games.each do |game| %>
        <tr>
          <td><%= image_tag(game.trophy_lists.first.icon_url, width: 107, height: 59) %></td>
          <td><%= game.name %></td>
          <td><%= game.platforms.map { |l|  l.abbreviation }.join(", ") %></td>
          <% if user_signed_in? %>
            <td>
              <%= form_with url: game_path(game.id),
                            method: :patch,
                            data: { controller: "update-game-status", update_game_status_target: "form", turbo_frame: "games" } do |f| %>
                <%= f.select :status,
                             options_for_select(
                               GameStatus.statuses.keys,
                               game.game_statuses.select { |status| status.user_id == current_user.id }&.first&.status
                             ),
                             { include_blank: true },
                             data: { action: "change->update-game-status#update" },
                             class: "form-control-dark text-bg-dark form-select" %>
              <% end %>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
