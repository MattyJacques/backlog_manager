<div id="search" class="text-end">
  <%= form_with url: list_games_path,
                method: :get,
                data: { controller: "search-form", search_form_target: "form", turbo_frame: "games" } do |f| %>
    <%= f.text_field :name,
                      placeholder: "Search...",
                      value: session.dig('game_filters', 'name'),
                      autocomplete: "off",
                      data: { action: "input->search-form#search"},
                      class: "form-control form-control-dark text-bg-dark" %>
    <%= f.select :platform_id,
                 options_for_select(
                   Platform.all.pluck(:name, :id),
                   session.dig('game_filters', 'platform_id')
                 ),
                 { include_blank: 'All Platforms' },
                 data: { action: "change->search-form#search" },
                 class: "form-control form-control-dark text-bg-dark form-select" %>
  <% end %>
</div>
<%= turbo_frame_tag "games" do %>
  <table id="games_table" class="table table-striped table-hover">
    <thead class="table-dark">
      <tr>
        <th scope="col">
          <%= build_order_link(label: "Name", sort_by: "name") %>
          <%= sort_indicator if session.dig('game_filters', 'sort_by') == "name" %>
        </th>
        <th scope="col">
          <%= build_order_link(label: "Platforms", sort_by: "platform") %>
          <%= sort_indicator if session.dig('game_filters', 'sort_by') == "platform" %>
        </th>
      </tr>
    </thead>
    <tbody class="table-dark">
      <% games.each do |game| %>
        <tr>
          <td><%= game.name %></td>
          <td><%= game.platforms.map { |l|  l.abbreviation }.join(", ") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
